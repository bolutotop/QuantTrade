# Nginx 反代配置示例
#
# 把 /webhook 单独反代到 127.0.0.1:9000（webhook 监听器）
# 把其它流量反代到 127.0.0.1:3000（Next.js 主应用）
#
# 用法：
#   1. 把本文件复制为 /etc/nginx/sites-available/quanttrade.conf
#   2. ln -s /etc/nginx/sites-available/quanttrade.conf /etc/nginx/sites-enabled/
#   3. 把 server_name 改成你的域名
#   4. 用 certbot 自动配置 https：
#      sudo certbot --nginx -d your-domain.com
#   5. nginx -t && systemctl reload nginx
#
# GitHub Webhook 的 Payload URL 填：
#   https://your-domain.com/webhook
# Content type 选 application/json
# Secret 与 ecosystem 里的 WEBHOOK_SECRET 完全一致

server {
    listen 80;
    server_name your-domain.com;

    # 让 certbot 把这块自动改写为 443 + 证书；这里保留 80 用于 challenge
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    server_name your-domain.com;

    # ssl_certificate     /etc/letsencrypt/live/your-domain.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/your-domain.com/privkey.pem;

    client_max_body_size 20M;   # 反馈截图最多 5 张 × 5MB

    # ----- GitHub Webhook -----
    # 只暴露 /webhook，其它 webhook 路径（如 /log）不对外
    location = /webhook {
        proxy_pass http://127.0.0.1:9000/webhook;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 600s;
    }

    # ----- 部署日志（仅自己看；建议加 IP 白名单或 basic auth） -----
    location = /deploy/log {
        # 仅允许指定 IP 访问；按需修改
        # allow 1.2.3.4;
        # deny all;

        # 或者用 basic auth：
        # auth_basic "Restricted";
        # auth_basic_user_file /etc/nginx/.htpasswd;

        proxy_pass http://127.0.0.1:9000/log;
    }

    # ----- Next.js 主应用 -----
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # 静态资源走长缓存
        # 反馈截图通过 /api/issue-images 路由，已自带 Cache-Control
    }

    # 反馈截图：可选的更激进缓存
    location /_next/static/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_cache_valid 200 30d;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }
}
